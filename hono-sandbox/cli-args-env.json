{
  "name": "hono-sandbox",
  "description": "Deno worker sandbox server",
  "options": {
    "port": {
      "type": "number",
      "env": "PORT",
      "default": 2584,
      "description": "HTTP listen port"
    },
    "hostname": {
      "type": "string",
      "env": "HOSTNAME",
      "default": "127.0.0.1",
      "description": "HTTP listen hostname"
    },
    "timeout-ms": {
      "type": "number",
      "env": "SANDBOX_TIMEOUT_MS",
      "description": "Default execution timeout in milliseconds"
    }
  }
}
