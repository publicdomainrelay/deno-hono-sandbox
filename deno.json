{
  "workspace": [
    "lib/common",
    "lib/abc/sandbox",
    "lib/sandbox-deno",
    "lib/hono-factory-sandbox-deno",
    "hono-sandbox"
  ],
  "nodeModulesDir": "auto",
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "check": "deno check lib/common/mod.ts lib/abc/sandbox/mod.ts lib/sandbox-deno/mod.ts lib/hono-factory-sandbox-deno/mod.ts hono-sandbox/mod.ts",
    "dev": "deno run --allow-env --allow-read --allow-net --unstable-worker-options hono-sandbox/mod.ts",
    "test": "deno test --allow-env --allow-read --unstable-worker-options test/",
    "test:sandbox": "deno test --allow-env --allow-read --unstable-worker-options test/sandbox/",
    "test:factory": "deno test --allow-env --allow-read --unstable-worker-options test/hono-factory/",
    "fmt": "deno fmt"
  },
  "fmt": {
    "lineWidth": 100
  },
  "unstable": ["worker-options"]
}
