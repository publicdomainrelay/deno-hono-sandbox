{
  "lexicon": 1,
  "id": "com.publicdomainrelay.temp.compute.deno.executeWorkerInstance",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Execute an HTTP-style request against a running worker instance. Forwards the request to the persistent Deno Worker via its message channel and returns the response.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["instance", "request"],
          "properties": {
            "instance": {
              "type": "ref",
              "ref": "com.atproto.repo.strongRef",
              "description": "StrongRef to a running com.publicdomainrelay.temp.compute.deno.workerInstance record."
            },
            "request": {
              "type": "ref",
              "ref": "com.publicdomainrelay.temp.compute.deno.workerRequest",
              "description": "The HTTP request to forward to the worker."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "integer",
              "description": "HTTP status code from the worker."
            },
            "headers": {
              "type": "object",
              "description": "Response headers.",
              "additionalProperties": { "type": "string" }
            },
            "body": {
              "type": "unknown",
              "description": "Response body from the worker."
            }
          }
        }
      },
      "errors": [
        { "name": "InstanceNotRunning", "description": "The referenced worker instance is not currently running." },
        { "name": "WorkerTimeout", "description": "The worker did not respond within the timeout." },
        { "name": "Unauthorized", "description": "Missing or invalid service-auth token." }
      ]
    }
  }
}
