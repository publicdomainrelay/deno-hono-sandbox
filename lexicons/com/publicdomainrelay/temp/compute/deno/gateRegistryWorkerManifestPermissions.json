{
  "lexicon": 1,
  "id": "com.publicdomainrelay.temp.compute.deno.gateRegistryWorkerManifestPermissions",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Evaluate a worker manifest against the configured permission policy. Returns allow (boolean) and a list of violations. Called by services implementing by-policy permission mode.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["manifest"],
          "properties": {
            "manifest": {
              "type": "ref",
              "ref": "com.publicdomainrelay.temp.compute.deno.workerManifest",
              "description": "The worker manifest record to evaluate."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["allow", "violations"],
          "properties": {
            "allow": {
              "type": "boolean",
              "description": "Whether the manifest is permitted by policy."
            },
            "violations": {
              "type": "array",
              "description": "Policy violations. Empty when allow is true.",
              "items": {
                "type": "object",
                "required": ["service", "scope", "policyId", "msg"],
                "properties": {
                  "service": { "type": "string", "format": "did" },
                  "scope": { "type": "string" },
                  "policyId": { "type": "string" },
                  "msg": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "errors": [
        { "name": "Unauthorized", "description": "Missing or invalid service-auth token." }
      ]
    }
  }
}
