{
  "lexicon": 1,
  "id": "com.publicdomainrelay.temp.compute.deno.registerWorkerManifest",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Register a worker manifest. The server bundles the provided source against the given deno.json, creates a signed workerManifest record and a workerInstance record on the configured PDS. If persistent is true, the worker instance is started immediately. Returns a strongRef to the created workerInstance together with the generated bundle.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["source", "denoJson"],
          "properties": {
            "source": {
              "type": "string",
              "description": "Worker source code (TypeScript)."
            },
            "denoJson": {
              "type": "string",
              "description": "Contents of deno.json for the worker project."
            },
            "denoLock": {
              "type": "string",
              "description": "Contents of deno.lock (optional)."
            },
            "persistent": {
              "type": "boolean",
              "description": "If true, the worker instance is started immediately after registration."
            },
            "permissionMode": {
              "type": "string",
              "enum": ["deny-all", "allow-all", "by-policy"],
              "description": "How to handle worker permissions. deny-all: strip all permissions (default). allow-all: grant all requested permissions. by-policy: evaluate via configured permission policy handler.",
              "default": "deny-all"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["instance", "bundle"],
          "properties": {
            "instance": {
              "type": "ref",
              "ref": "com.atproto.repo.strongRef",
              "description": "StrongRef (uri + cid) to the created workerInstance record."
            },
            "bundle": {
              "type": "string",
              "description": "The generated bundle.js contents."
            },
            "violations": {
              "type": "array",
              "description": "Permission policy violations, populated when permissionMode=by-policy and policy denies registration.",
              "items": {
                "type": "object",
                "required": ["service", "scope", "policyId", "msg"],
                "properties": {
                  "service": { "type": "string" },
                  "scope": { "type": "string" },
                  "policyId": { "type": "string" },
                  "msg": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "errors": [
        { "name": "BundleFailed", "description": "Source code failed to bundle/validate." },
        { "name": "PermissionDenied", "description": "Permission policy denied registration." },
        { "name": "Unauthorized", "description": "Missing or invalid service-auth token." }
      ]
    }
  }
}
