{
  "lexicon": 1,
  "id": "com.publicdomainrelay.temp.compute.deno.runPersistentWorkerInstance",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Start a persistent worker instance from a registered manifest. Creates a signed com.publicdomainrelay.temp.compute.deno.workerInstance record on the PDS, then spawns a long-lived Deno Worker from the manifest's bundle.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["manifest"],
          "properties": {
            "manifest": {
              "type": "ref",
              "ref": "com.atproto.repo.strongRef",
              "description": "StrongRef to a registered com.publicdomainrelay.temp.compute.deno.workerManifest record."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["instance"],
          "properties": {
            "instance": {
              "type": "ref",
              "ref": "com.atproto.repo.strongRef",
              "description": "StrongRef to the created com.publicdomainrelay.temp.compute.deno.workerInstance record."
            }
          }
        }
      },
      "errors": [
        { "name": "ManifestNotFound", "description": "The referenced workerManifest record was not found." },
        { "name": "WorkerStartFailed", "description": "The persistent worker failed to start." },
        { "name": "Unauthorized", "description": "Missing or invalid service-auth token." }
      ]
    }
  }
}
